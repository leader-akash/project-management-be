NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/internal_project_management
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://127.0.0.1:6379
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional: registering with this email becomes workspace admin (in addition to first-user bootstrap).
COMPANY_ADMIN_EMAIL=admin@project.com

# Seed one admin (npm run seed:admin)
SEED_ADMIN_EMAIL=admin@project.com
SEED_ADMIN_PASSWORD=admin@123
SEED_ADMIN_NAME=Workspace Admin

